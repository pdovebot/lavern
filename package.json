{
  "name": "lavern",
  "version": "0.15.0",
  "description": "Lavern — An agentic legal architecture. A law firm staffed with AI agents.",
  "license": "Apache-2.0",
  "author": "Antti Innanen (https://lavern.ai)",
  "homepage": "https://lavern.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnttiHero/lavern.git"
  },
  "bugs": {
    "url": "https://github.com/AnttiHero/lavern/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shem": "bin/lavern.js",
    "lavern": "bin/lavern.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx scripts/onboard.ts",
    "dev": "NODE_OPTIONS='--no-deprecation' tsx --env-file-if-exists=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "protect": "gitleaks protect --staged --no-banner --config .gitleaks.toml",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit && cd viz && npx tsc --noEmit",
    "serve": "NODE_OPTIONS='--no-deprecation' tsx --env-file-if-exists=.env src/index.ts --serve",
    "serve:dev": "NODE_OPTIONS='--no-deprecation' tsx --env-file-if-exists=.env src/index.ts --serve --port 3000",
    "build:viz": "cd viz && npm run build",
    "build:site": "cd viz && VITE_BASE_PATH=/demo/ npm run build && rm -rf ../site/demo && cp -R dist ../site/demo && echo 'site/demo rebuilt. Drag site/ to Netlify when ready.'"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.38",
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@resvg/resvg-js": "^2.6.2",
    "@stripe/stripe-js": "^8.9.0",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.6.0",
    "fastify": "^5.7.4",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "openai": "^4.85.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.1.3",
    "prompts": "^2.4.2",
    "puppeteer": "^24.39.1",
    "resend": "^6.9.3",
    "satori": "^0.26.0",
    "stripe": "^20.4.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/prompts": "^2.4.9",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "private": true
}
