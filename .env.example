# ─────────────────────────────────────────────────────────────────────────────
# Lavern — environment configuration
#
# Three install profiles, top to bottom:
#   1. CLOUD (Anthropic) — default. Best capability. Requires an API key.
#   2. LOCAL (Ollama)    — on-device. Free. Requires Ollama + a pulled model.
#   3. EU SOVEREIGN      — Mistral (EU-hosted). For GDPR-bound matters.
#
# Pick ONE profile by uncommenting the LAVERN_PROVIDER line in that section
# and setting the keys it needs. The others can stay commented — they're
# inert when not the active provider.
# ─────────────────────────────────────────────────────────────────────────────


# ── Profile 1: CLOUD (Anthropic) — DEFAULT ───────────────────────────────────
# Routes every LLM call through Anthropic's API. The fastest path to a working
# install: paste your key, run `npm run dev -- --serve`, and engagements
# process end-to-end. Get a key at https://console.anthropic.com/settings/keys
#
LAVERN_PROVIDER=anthropic
ANTHROPIC_API_KEY=

SHEM_MODEL=claude-opus-4-7
SHEM_ROUTER_MODEL=claude-sonnet-4-5


# ── Profile 2: LOCAL (Ollama) ────────────────────────────────────────────────
# Runs entirely on this machine via Ollama. Zero data leaves the host. Free.
#
# Prerequisites:
#   1. Install Ollama from https://ollama.com
#   2. Pull a model that fits your laptop:
#        - 16 GB+ RAM:  ollama pull gemma3:4b   (recommended)
#        - 8 GB RAM:    ollama pull gemma2:2b   (smaller, lower quality)
#   3. Comment out the Anthropic block above, uncomment the lines below,
#      and set LAVERN_LOCAL_DEFAULT_MODEL to the model you pulled.
#
# Heads-up: local models have small context windows and weaker reasoning
# than Claude. Multi-agent debate quality drops noticeably. Use Anthropic
# for serious matters; use local for offline tinkering and privacy demos.
#
# LAVERN_PROVIDER=local
# LAVERN_LOCAL_URL=http://localhost:11434
# LAVERN_LOCAL_DEFAULT_MODEL=gemma3:4b
# LAVERN_LOCAL_ROUTER_MODEL=gemma3:4b
# LAVERN_LOCAL_ASSEMBLY_MODEL=gemma3:4b


# ── Profile 3: EU SOVEREIGN (Mistral) ────────────────────────────────────────
# EU-hosted inference. For GDPR-bound matters. Requires a Mistral key.
# Get a key at https://console.mistral.ai/api-keys
#
# LAVERN_PROVIDER=mistral
# MISTRAL_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
# Everything below is optional — sensible defaults work for a local install.
# ─────────────────────────────────────────────────────────────────────────────


# ── Budgets ──────────────────────────────────────────────────────────────────
SHEM_DEFAULT_BUDGET=5.00
SHEM_MAX_TURNS=80
SHEM_GENERIC_MAX_TURNS=60


# ── Paths ────────────────────────────────────────────────────────────────────
SHEM_AUDIT_DIR=./audit-logs
SHEM_MEMORY_DIR=.shem/memory
SHEM_REPORTS_DIR=.shem/reports
SHEM_BASELINES_DIR=.shem/baselines
SHEM_DB_PATH=./data/lavern.db


# ── API Server ───────────────────────────────────────────────────────────────
SHEM_PORT=3000
SHEM_HOST=0.0.0.0
SHEM_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
SHEM_BASE_URL=http://localhost:3000
# SHEM_TRUST_PROXY=true
# SHEM_MAX_UPLOAD_BYTES=10000000


# ── Rate Limiting ────────────────────────────────────────────────────────────
# SHEM_RATE_LIMIT_MAX=100
# SHEM_RATE_LIMIT_WINDOW_MS=60000
# SHEM_RATE_LIMIT_SESSION_MAX=10
# SHEM_RATE_LIMIT_AUTH_LOGIN_MAX=5
# SHEM_RATE_LIMIT_AUTH_SIGNUP_MAX=3


# ── Per-User Rate Limiting ───────────────────────────────────────────────────
# SHEM_RATE_LIMIT_USER_MAX=30
# SHEM_RATE_LIMIT_USER_WINDOW_MS=60000
# SHEM_MAX_USER_SESSIONS=5


# ── Email (Resend) — optional ────────────────────────────────────────────────
# Without this, password resets and email verification are disabled. Local
# installs typically don't need it (single user, no auth).
# RESEND_API_KEY=...


# ── Stripe Billing — optional ────────────────────────────────────────────────
# Local installs run with billing disabled. Cloud SaaS deployments need this.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SUCCESS_URL=https://app.lavern.ai/?billing=success
# STRIPE_CANCEL_URL=https://app.lavern.ai/?billing=cancelled


# ── Error Monitoring (Sentry) — optional ─────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...


# ── Sessions ─────────────────────────────────────────────────────────────────
# SHEM_SESSION_TTL_MS=14400000
# SHEM_MAX_SESSIONS=100


# ── Logging ──────────────────────────────────────────────────────────────────
SHEM_LOG_LEVEL=info
# SHEM_LOG_DIR=./logs
# SHEM_LOG_RETAIN_DAYS=14


# ── WebSocket ────────────────────────────────────────────────────────────────
# SHEM_MAX_WS_CONNECTIONS=200


# ── Claw Mode (Law Firm on Retainer) — optional ──────────────────────────────
# Background document processing daemon. Off by default.
# LAVERN_CLAW_DIR=~/.lavern
# LAVERN_CLAW_BUDGET=50.0
# LAVERN_CLAW_PER_DOC_BUDGET=10.0
# LAVERN_CLAW_SCAN_INTERVAL=30000
# LAVERN_CLAW_MAX_FILE_SIZE=10485760
# LAVERN_CLAW_MAX_DOCS_PER_SCAN=50
# LAVERN_CLAW_WEBHOOK_URL=https://hooks.slack.com/...
# LAVERN_CLAW_MACOS_NOTIFY=true
# LAVERN_CLAW_NOTIFY_DEDUP_MS=300000


# ── Claw: Heartbeat ──────────────────────────────────────────────────────────
# LAVERN_CLAW_HEARTBEAT=true
# LAVERN_CLAW_HEARTBEAT_INTERVAL=1800000
