# Lavern — Reverse proxy with automatic HTTPS
#
# Place this at /etc/caddy/Caddyfile on the Mac Mini.
# Caddy will auto-obtain and renew TLS certificates via Let's Encrypt.
#
# Replace lavern.example.com with your actual domain.
# For LAN-only: use `mkcert` for a self-signed cert.
#
# Install: brew install caddy
# Start:   sudo caddy start --config /etc/caddy/Caddyfile
#
# Set SHEM_TRUST_PROXY=true in .env when running behind this proxy.

lavern.example.com {
    reverse_proxy localhost:3000
}
