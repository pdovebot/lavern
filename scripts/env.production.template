# Lavern — Production Environment
#
# Copy this to .env and fill in your values:
#   cp scripts/env.production.template .env

# ── Required ──────────────────────────────────────────────────────────────

# Your Anthropic API key
# For better security, store in macOS Keychain instead:
#   ./scripts/keychain-setup.sh store
ANTHROPIC_API_KEY=sk-ant-...

# ── Models ────────────────────────────────────────────────────────────────

# Primary model for orchestration and analysis (default: claude-opus-4-7)
SHEM_MODEL=claude-opus-4-7
# Router model for request classification (default: claude-sonnet-4-5)
SHEM_ROUTER_MODEL=claude-sonnet-4-5

# ── API Server ────────────────────────────────────────────────────────────

SHEM_PORT=3000
SHEM_HOST=0.0.0.0
SHEM_BASE_URL=https://lavern.example.com
SHEM_LOG_LEVEL=info
SHEM_CORS_ORIGINS=*
# Max upload file size in bytes (default: 10 MB)
SHEM_MAX_UPLOAD_BYTES=10000000

# ── TLS / Reverse Proxy ──────────────────────────────────────────────────
# When behind a reverse proxy (Caddy, nginx), enable trust proxy
# so Fastify reads X-Forwarded-For and X-Forwarded-Proto correctly.
# See scripts/Caddyfile.example for a ready-to-use TLS config.
SHEM_TRUST_PROXY=true

# ── Rate Limiting ─────────────────────────────────────────────────────────

# Max requests per window per IP (default: 100)
SHEM_RATE_LIMIT_MAX=100
# Rate limit window in ms (default: 60000 = 1 minute)
SHEM_RATE_LIMIT_WINDOW_MS=60000
# Max session-creation requests per window per IP (default: 10)
SHEM_RATE_LIMIT_SESSION_MAX=10

# ── Sessions ──────────────────────────────────────────────────────────────

# Session TTL in ms before eviction (default: 14400000 = 4 hours)
SHEM_SESSION_TTL_MS=14400000
# Max concurrent sessions (default: 100)
SHEM_MAX_SESSIONS=100
# Default budget per session in USD (default: 5.0)
SHEM_DEFAULT_BUDGET=5.0
# Max orchestrator turns (default: 80)
SHEM_MAX_TURNS=80
# Max turns for generic/simple workflows (default: 60)
SHEM_GENERIC_MAX_TURNS=60

# ── Gates ─────────────────────────────────────────────────────────────────

# Webhook gate timeout in ms (default: 30000 = 30s)
SHEM_GATE_WEBHOOK_TIMEOUT_MS=30000

# ── Data Paths ────────────────────────────────────────────────────────────

# SQLite database for user auth, sessions, matters
SHEM_DB_PATH=./data/lavern.db
# Audit log directory
SHEM_AUDIT_DIR=./audit-logs
# Memory system directories (institutional memory, precedents, matter memory)
SHEM_MEMORY_DIR=.shem/memory
SHEM_REPORTS_DIR=.shem/reports
SHEM_BASELINES_DIR=.shem/baselines

# ── Payment (x402 — USDC on Base) ────────────────────────────────────────
# Enable x402 protocol for pay-per-use access to /api/engage
# When enabled, unauthenticated callers receive 402 with payment instructions
SHEM_X402_ENABLED=false
SHEM_X402_RECIPIENT=

# ── Claw Mode (Law Firm on Retainer) ─────────────────────────────────────

LAVERN_CLAW_DIR=/opt/lavern/.lavern
LAVERN_CLAW_BUDGET=100.0
LAVERN_CLAW_PER_DOC_BUDGET=10.0
# Scan interval in ms (default: 30000 = 30s)
LAVERN_CLAW_SCAN_INTERVAL=30000

# Claw Mode — Security
LAVERN_CLAW_MAX_FILE_SIZE=10485760
LAVERN_CLAW_MAX_DOCS_PER_SCAN=50

# Claw Mode — Notifications
# Set webhook URL for Slack/Discord/generic JSON notifications
LAVERN_CLAW_WEBHOOK_URL=
# macOS native notifications (disable with 'false')
LAVERN_CLAW_MACOS_NOTIFY=true
# Notification dedup window in ms (default: 300000 = 5 minutes)
LAVERN_CLAW_NOTIFY_DEDUP_MS=300000

# Claw Mode — Local Model (Confidential Document Analysis)
# When set, documents matching sensitivity patterns are analyzed on-device.
# No content is transmitted to any external API. Preserves attorney-client privilege.
# Requires Ollama: brew install ollama && ollama pull llama3.1:8b
LAVERN_LOCAL_MODEL_URL=http://localhost:11434
LAVERN_LOCAL_MODEL=llama3.1:8b
LAVERN_LOCAL_ANALYSIS_MODEL=llama3.1:70b

# ── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=production
